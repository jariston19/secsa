# Default: LAN / lab — internal TLS (browser shows a one-time certificate warning).
# For a public domain + Let's Encrypt, replace this file with:
#
#   exam.yourschool.edu {
#     reverse_proxy frontend:80
#   }
#
#   :80 {
#     redir https://exam.yourschool.edu{uri} permanent
#   }

:443 {
	tls internal
	reverse_proxy frontend:80
}

:80 {
	redir https://{host}:5173{uri} permanent
}
